# ============================================================
# ESTYM_AI Platform Configuration
# Copy to .env and fill in your values
# ============================================================

# --- LLM Providers ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=estym_ai
POSTGRES_USER=estym
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://estym:changeme@localhost:5432/estym_ai

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=raw-uploads
MINIO_BUCKET_PROCESSED=processed
MINIO_BUCKET_THUMBNAILS=thumbnails
MINIO_USE_SSL=false

# --- Email Monitoring ---
EMAIL_PROVIDER=imap
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=kosztorys@firma.pl
IMAP_PASSWORD=changeme
# For MS Graph API:
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=
# MS_GRAPH_TENANT_ID=

# --- ERP Graffiti Integration ---
GRAFFITI_ERP_MODE=api
GRAFFITI_ERP_API_URL=http://localhost:8080/api
GRAFFITI_ERP_API_KEY=
# For DB mode:
# GRAFFITI_ERP_DB_URL=mssql+pyodbc://...

# --- Werk24 OCR (optional, commercial) ---
WERK24_API_KEY=

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=changeme-in-production
LOG_LEVEL=INFO

# --- Cost Calculation Defaults ---
SOCIAL_OVERHEAD_PERCENT=10
DEFAULT_CURRENCY=PLN
